# Base de données
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace?schema=public"
# PRISMA_LOG=none   # optionnel : désactive les logs Prisma (sinon muets pendant `next build` via NEXT_PHASE)

# Auth (Auth.js — Phase 4)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET=""   # openssl rand -base64 32

# Chariow (serveur uniquement — jamais exposé au client)
# CHARIOW_API_KEY=""
# CHARIOW_API_URL="https://api.chariow.com/v1"
# CHARIOW_PRODUCT_ID=""     # License product ID créé dans Chariow Dashboard
# CHARIOW_WEBHOOK_SECRET="" # Secret pour valider les Pulses (webhooks)

# Stockage objet S3-compatible (Phase 4)
# S3_ENDPOINT=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_BUCKET=""
# S3_REGION=""

# File d’e-mails PostgreSQL (Phase 4.64) — cron `/api/cron/outbox` (Authorization: Bearer … ou `?secret=`)
# CRON_SECRET=""   # openssl rand -base64 32

# Email (Phase 4)
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM=""

# Redis (Phase 4 — jobs / queues)
# REDIS_URL="redis://localhost:6379"

# Push notifications (Phase 6.1) — generer avec : npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_MAILTO="mailto:admin@votre-domaine.com"

# Application
NEXT_PUBLIC_APP_NAME="Marketplace"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="fr"

# Lancement (Phase 4.60) — optionnel
# NEXT_PUBLIC_MAINTENANCE_BANNER=1
# NEXT_PUBLIC_MAINTENANCE_MESSAGE="Maintenance planifiée ce soir de 22h à 23h UTC."
# NEXT_PUBLIC_APP_RELEASE_LABEL=v0.1.0   # affiché sur /statut et /aide/versions (gel / release)
# NEXT_PUBLIC_EXTERNAL_STATUS_URL=https://status.votredomaine.com   # lien optionnel (Better Stack, Statuspage…)

# Post go-live (Phase 4.61) — feature flags serveur uniquement
# FEATURE_BETA_SELLER_ANALYTICS=1

# ── Production (Phase 4.58) — renseigner sur l’hébergeur, ne pas committer ──
# NODE_ENV est généralement défini automatiquement (ex. "production").
# NEXTAUTH_URL="https://votre-domaine.com"   # obligatoire : URL publique HTTPS
# NEXT_PUBLIC_APP_URL="https://votre-domaine.com"   # aligné sur NEXTAUTH_URL
# DATABASE_URL="postgresql://...?sslmode=require"
#
# Contact formulaire (optionnel)
# CONTACT_EMAIL="support@votre-domaine.com"
#
# Monitoring — Sentry (Phase 4.62, voir docs/deploiement.md §6)
# NEXT_PUBLIC_SENTRY_DSN=""   # obligatoire pour erreurs navigateur (DSN public du projet)
# SENTRY_DSN=""               # optionnel serveur (sinon init serveur peut réutiliser la logique documentée)
# SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# SENTRY_AUTH_TOKEN=""        # CI : upload source maps (secret)
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Sécurité HTTP (Phase 4.59) — activer uniquement en production HTTPS de bout en bout
# ENABLE_HSTS=1              # Strict-Transport-Security (build time dans next.config)
# ENABLE_CSP_UPGRADE=1       # upgrade-insecure-requests dans la CSP

# Images (Next.js Image — Phase 4.57)
# Les avatars OAuth (Google, GitHub, Gravatar) sont déjà autorisés dans next.config.ts.
# Pour un CDN / R2 / S3 public, ajoutez le hostname dans images.remotePatterns (next.config.ts).
